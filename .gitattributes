# Handle line endings automatically
* text=auto

# Explicitly set LF for these file types
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.env*      text eol=lf

# Binary files — don't touch these
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.woff2     binary